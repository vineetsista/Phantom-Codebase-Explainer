# === AI API Keys ===
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here  # Optional — falls back to OpenAI TTS

# === GitHub ===
GITHUB_TOKEN=your_github_token_here  # Optional — increases rate limit from 60 to 5000 req/hr

# === Database ===
DATABASE_URL=postgresql://phantom:phantom@localhost:5432/phantom

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === App ===
APP_URL=http://localhost:3000
API_URL=http://localhost:8000
SECRET_KEY=change_this_to_a_random_64_char_string_in_production

# === Video Pipeline ===
VIDEO_OUTPUT_DIR=./output/videos
THUMBNAIL_OUTPUT_DIR=./output/thumbnails
TEMP_DIR=./output/temp
MAX_REPO_SIZE_MB=100
DEFAULT_VOICE=openai        # openai | elevenlabs
DEFAULT_QUALITY=720p        # 720p | 1080p

# === Celery ===
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# === Frontend (Next.js public vars) ===
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000
